  "Module": {
    "1": {
      "title": "Softwareentwicklung",
      "dauer": 5,
      "beschreibung": "Grundlagen der Softwareentwicklung, inklusive Programmierung, Versionskontrolle und Best Practices.",
      "brauchtPC": true,
      "anzahlTrainer": 2,
      "vorgaengerModule": []
    },
    "2": {
      "title": "Netzwerktechnik Basics",
      "dauer": 2,
      "beschreibung": "Einführung in Netzwerktechnik, inklusive Konfiguration und Fehlerbehebung.",
      "brauchtPC": false,
      "anzahlTrainer": 1,
      "vorgaengerModule": ["1"]
    },
    "3": {
      "title": "Datenbankmanagement",
      "dauer": 3,
      "beschreibung": "Grundlagen relationaler Datenbanken, SQL-Abfragen, Datenbankdesign und Normalisierung.",
      "brauchtPC": true,
      "anzahlTrainer": 1,
      "vorgaengerModule": ["1"]
    },
    "4": {
      "title": "IT-Sicherheit Grundlagen",
      "dauer": 2,
      "beschreibung": "Einführung in Cybersecurity, Bedrohungsanalyse, Verschlüsselung und sichere Systeme.",
      "brauchtPC": false,
      "anzahlTrainer": 1,
      "vorgaengerModule": ["2"]
    },
    "5": {
      "title": "Webentwicklung Frontend",
      "dauer": 4,
      "beschreibung": "HTML, CSS und JavaScript für moderne Benutzeroberflächen, inklusive responsivem Design.",
      "brauchtPC": true,
      "anzahlTrainer": 2,
      "vorgaengerModule": ["1"]
    },
    "6": {
      "title": "Cloud Computing",
      "dauer": 3,
      "beschreibung": "Grundlagen von Cloud-Infrastrukturen, Diensten und Deployment-Strategien (AWS, Azure, GCP).",
      "brauchtPC": true,
      "anzahlTrainer": 1,
      "vorgaengerModule": ["2", "3"]
    },
    "7": {
      "title": "Projektmanagement & Agile",
      "dauer": 2,
      "beschreibung": "Scrum, Kanban und klassisches Projektmanagement für IT-Projekte im Ausbildungskontext.",
      "brauchtPC": false,
      "anzahlTrainer": 1,
      "vorgaengerModule": []
    },
    "8": {
      "title": "Linux & Systemadministration",
      "dauer": 3,
      "beschreibung": "Umgang mit Linux-Betriebssystemen, Shell-Scripting, Rechteverwaltung und Serveradministration.",
      "brauchtPC": true,
      "anzahlTrainer": 2,
      "vorgaengerModule": ["2"]
    },
    "9": {
      "title": "Backend-Entwicklung & APIs",
      "dauer": 4,
      "beschreibung": "Entwicklung von REST-APIs und Backend-Logik mit Node.js oder Python, inklusive Authentifizierung.",
      "brauchtPC": true,
      "anzahlTrainer": 2,
      "vorgaengerModule": ["1", "3"]
    },
    "10": {
      "title": "DevOps & CI/CD",
      "dauer": 3,
      "beschreibung": "Automatisierung von Build- und Deployment-Prozessen mit Docker, GitHub Actions und Pipelines.",
      "brauchtPC": true,
      "anzahlTrainer": 1,
      "vorgaengerModule": ["6", "8"]
    },
    "11": {
      "title": "IT-Recht & Datenschutz",
      "dauer": 1,
      "beschreibung": "Grundlagen des IT-Rechts, DSGVO, Lizenzmodelle und rechtliche Rahmenbedingungen im Berufsalltag.",
      "brauchtPC": false,
      "anzahlTrainer": 1,
      "vorgaengerModule": []
    },
    "12": {
      "title": "Abschlussprojekt",
      "dauer": 6,
      "beschreibung": "Eigenständige Umsetzung eines praxisnahen IT-Projekts unter Anwendung aller erlernten Kompetenzen.",
      "brauchtPC": true,
